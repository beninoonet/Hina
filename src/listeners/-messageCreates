const { Listener, CommandOptionsRunTypeEnum } = require('@sapphire/framework');
const { ChannelType } = require('discord.js');
const dotenv = require('dotenv');
dotenv.config();

class DMToTicket extends Listener {
  constructor(context, options) {
    super(context, {
      ...options,
      once: false,
      event: 'messageCreate',
    });
  }

    async run(message) {
        if (message.author.bot) return;

    // Fetch le channel partial avant de vérifier le type
    if (message.channel.partial) await message.channel.fetch();

    // Utilise la valeur numérique directement
    if (message.channel.type !== 1) return; // 1 = DM

    console.log('✅ DM reçu de', message.author.tag, ':', message.content);
    }

}
module.exports = {
  DMToTicket
};